{
  "name": "taskingen",
  "displayName": "Taskingen",
  "description": "Run npm and shell scripts from the Explorer sidebar.",
  "version": "0.1.1",
  "publisher": "cemcakirlar",
  "icon": "media/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cemcakirlar/taskingen.git"
  },
  "bugs": {
    "url": "https://github.com/cemcakirlar/taskingen/issues"
  },
  "homepage": "https://github.com/cemcakirlar/taskingen#readme",
  "keywords": [
    "scripts",
    "npm",
    "shell",
    "tasks",
    "terminal",
    "explorer"
  ],
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "compile:test": "tsc -p tsconfig.test.json",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "publish": "vsce publish",
    "publish:ovsx": "ovsx publish",
    "test": "npm run test:unit",
    "test:unit": "npm run compile:test && node --require ./test/helpers/register-vscode-mock.cjs --test 'out-test/test/unit/**/*.test.js'",
    "test:integration": "npm run compile:test && node --require ./test/helpers/register-vscode-mock.cjs --test 'out-test/test/integration/**/*.test.js'",
    "test:e2e": "npm run compile:test && node --require ./test/helpers/register-vscode-mock.cjs --test 'out-test/test/e2e/**/*.test.js'"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.125.0",
    "@vscode/vsce": "^3.9.2",
    "ovsx": "^1.0.2",
    "typescript": "^5.8.0"
  },
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "taskingen.scripts",
          "name": "Taskingen",
          "contextualTitle": "Taskingen"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "taskingen.scripts",
        "contents": "Open a folder to discover npm and shell scripts.\n[Open Folder](command:vscode.openFolder)",
        "when": "workbenchState == empty"
      }
    ],
    "commands": [
      {
        "command": "taskingen.open",
        "title": "Taskingen: Open Script Source",
        "icon": "$(go-to-file)"
      },
      {
        "command": "taskingen.run",
        "title": "Taskingen: Run Script",
        "icon": "$(play)"
      },
      {
        "command": "taskingen.stop",
        "title": "Taskingen: Stop Script",
        "icon": "$(debug-stop)"
      },
      {
        "command": "taskingen.refresh",
        "title": "Taskingen: Refresh Scripts",
        "icon": "$(refresh)"
      },
      {
        "command": "taskingen.clearHistory",
        "title": "Taskingen: Clear Task History",
        "icon": "$(clear-all)"
      },
      {
        "command": "taskingen.activateScript",
        "title": "Taskingen: Activate Script"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "taskingen.refresh",
          "when": "view == taskingen.scripts",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "taskingen.open",
          "when": "view == taskingen.scripts && (viewItem == npmScript || viewItem == shellScript || viewItem == npmScriptRunning || viewItem == shellScriptRunning)",
          "group": "inline@1"
        },
        {
          "command": "taskingen.run",
          "when": "view == taskingen.scripts && (viewItem == npmScript || viewItem == shellScript)",
          "group": "inline@2"
        },
        {
          "command": "taskingen.stop",
          "when": "view == taskingen.scripts && (viewItem == npmScriptRunning || viewItem == shellScriptRunning)",
          "group": "inline@2"
        },
        {
          "command": "taskingen.clearHistory",
          "when": "view == taskingen.scripts && viewItem == taskHistory",
          "group": "inline@1"
        }
      ]
    },
    "configuration": {
      "title": "Taskingen",
      "properties": {
        "taskingen.npmScriptGrouping.separator": {
          "type": "string",
          "default": ":",
          "description": "Literal separator used to nest npm script names under project folders. An empty value disables grouping."
        },
        "taskingen.npmScriptGrouping.maxDepth": {
          "type": "integer",
          "default": 1,
          "minimum": 0,
          "maximum": 10,
          "description": "Maximum number of separator-based group levels under each project. Use 0 to disable grouping."
        },
        "taskingen.npmProjectGrouping.groupByScope": {
          "type": "boolean",
          "default": true,
          "description": "Group scoped npm packages (for example @cemcakirlar/mst-tab-sync) under a shared @scope node."
        },
        "taskingen.scriptClickAction": {
          "type": "string",
          "enum": [
            "open",
            "execute"
          ],
          "default": "open",
          "description": "What happens when you activate a script name in the tree (see Script Click Mode). Inline Open and Run actions remain available either way.",
          "enumDescriptions": [
            "Open the package.json script entry or shell script file in the editor.",
            "Run the script in the terminal."
          ]
        },
        "taskingen.scriptClickMode": {
          "type": "string",
          "enum": [
            "singleClick",
            "doubleClick"
          ],
          "default": "doubleClick",
          "description": "Whether the configured script action runs on a single click or a double click. Interacts with workbench.list.openMode: when that setting is doubleClick, Taskingen activates when the tree item opens (typically on double click).",
          "enumDescriptions": [
            "Activate the script when the tree item opens on a single click (or on double click if workbench.list.openMode is doubleClick).",
            "Activate the script on double click."
          ]
        },
        "taskingen.tree.defaultExpandedDepth": {
          "type": "integer",
          "default": 1,
          "minimum": 0,
          "maximum": 10,
          "description": "How many tree levels are expanded by default. 0 collapses everything, 1 expands only the root npm/shell groups, and higher values expand deeper project and script groups."
        },
        "taskingen.taskHistory.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show the Task History group at the top of the Taskingen tree with recently run scripts from the current workspace folder."
        },
        "taskingen.taskHistory.maxItems": {
          "type": "integer",
          "default": 5,
          "minimum": 1,
          "maximum": 50,
          "description": "How many recently run scripts to show under Task History."
        }
      }
    }
  }
}
